# Big Red Button Bingo – Environment Configuration
# Copy to .env and adjust as needed.

# HTTP server port (serves UI + API + WebSocket)
PORT=3000

# OSC listener port (UDP – QLab sends here)
OSC_PORT=8001

# OSC bind address (0.0.0.0 = all interfaces; use this in Docker)
OSC_INTERFACE=0.0.0.0

# Directory for SQLite database and logs
DATA_DIR=./data

# QLab outbound OSC host (where scoreboard updates are sent)
QLAB_HOST=127.0.0.1

# QLab outbound OSC port
QLAB_OSC_PORT=53000
